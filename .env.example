# 张雪峰数字分身 - 环境变量配置
# 复制此文件为 .env 并填入你的API密钥

# ============ 必填配置 ============

# DeepSeek API密钥
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 阿里云百炼API密钥
# 获取地址: https://dashscope.console.aliyun.com/apiKey
ALIYUN_API_KEY=sk-your-aliyun-api-key-here

# ============ 可选配置 ============

# 阿里云知识库ID (可选)
# 如果使用阿里云知识库功能，请填写你的知识库ID
KNOWLEDGE_BASE_ID=your-knowledge-base-id-here

# 腾讯云配置 (可选，用于语音合成)
# TENCENT_SECRET_ID=your-tencent-secret-id
# TENCENT_SECRET_KEY=your-tencent-secret-key
# TENCENT_SDK_APP_ID=your-sdk-app-id
# VOICE_ID=your-voice-id

# ============ Flask配置 ============

# Flask调试模式 (开发时设置为True)
# FLASK_DEBUG=True

# Flask运行主机 (默认0.0.0.0允许所有IP访问)
# FLASK_HOST=0.0.0.0

# Flask运行端口 (默认5000)
# FLASK_PORT=5000

# ============ 使用说明 ============
# 1. 复制此文件为 .env
# 2. 填入你的API密钥
# 3. 运行应用: python app.py
# 
# 注意: .env文件包含敏感信息，不要提交到版本控制系统
# 确保 .env 在 .gitignore 中